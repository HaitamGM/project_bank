# Copiez ce fichier en « .env » et mettez vos vraies valeurs (sans guillemets).

# --- Gemini (assistant vocal + explication crédit) ---
# Clé gratuite : https://aistudio.google.com  ->  "Get API key"
GOOGLE_API_KEY=votre_cle_ici
# Nom exact du modèle Gemini Live (vérifiez-le dans Google AI Studio).
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Modèle texte pour l'explication hybride de la pipeline (best-effort, repli gabarit).
GEMINI_TEXT_MODEL=gemini-flash-latest

# --- Sécurité ---
# Secret de signature des JWT — METTEZ UNE VALEUR ALÉATOIRE LONGUE.
# Générez-en un : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changez_moi_par_une_valeur_aleatoire
# Mot de passe de démo commun (haché en bcrypt au premier démarrage dans data/users.json).
DEMO_PASSWORD=BankIA@2026
# En mode démo, l'OTP est renvoyé au front pour la soutenance (mettez false en prod).
DEMO_MODE=true
