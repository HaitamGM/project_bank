# Copiez ce fichier en « .env » et mettez votre vraie clé (sans guillemets).
# Clé gratuite : https://aistudio.google.com
GOOGLE_API_KEY=votre_cle_ici

# Nom exact du modèle Gemini Live (vérifiez-le dans Google AI Studio).
# Si la connexion échoue avec une erreur de modèle, changez cette valeur ici
# sans toucher au code.
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
